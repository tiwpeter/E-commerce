// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator zod {
  provider = "zod-prisma-types"
  output   = "./generated/zod" // (Optional) กำหนดโฟลเดอร์ปลายทาง
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
}