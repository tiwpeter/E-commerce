# ======================================================
# SHOPTHAI — Environment Variables
# ======================================================
# คัดลอกไฟล์นี้ไปเป็น .env.local แล้วแก้ค่าให้ถูกต้อง
# cp .env.example .env.local

# URL ของ Backend API (ไม่ต้องมี trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# (Optional) ถ้าใช้ Next.js API Proxy จะใช้ตัวนี้แทน
# API_URL=http://localhost:4000/api
